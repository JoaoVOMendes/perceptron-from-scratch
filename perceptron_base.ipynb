# ============================================
# CÓDIGO BASE — Perceptron com dados aleatórios
# ============================================
import numpy as np
import matplotlib.pyplot as plt

# Gerar conjunto de dados
np.random.seed(0)
X = np.random.randn(100, 2)
y = np.where(X[:, 0] + X[:, 1] > 0, 1, -1)

# Função de previsão
def predict(x, weights, bias):
    return np.where(np.dot(x, weights) + bias >= 0, 1, -1)

# Função de treinamento do Perceptron
def train_perceptron(X, y, learning_rate=0.1, epochs=10):
    weights = np.zeros(X.shape[1])
    bias = 0
    for epoch in range(epochs):
        errors = 0
        for xi, target in zip(X, y):
            update = learning_rate * (target - predict(xi, weights, bias))
            weights += update * xi
            bias += update
            if update != 0:
                errors += 1
        print(f"Época {epoch+1:2d} | Erros: {errors}")
    return weights, bias

# Treinar o Perceptron
print("=== Treinamento ===")
weights, bias = train_perceptron(X, y)
print(f"\nPesos finais: {weights}")
print(f"Bias final: {bias:.4f}")

# Acurácia
predicoes = predict(X, weights, bias)
acuracia = np.mean(predicoes == y) * 100
print(f"Acurácia: {acuracia:.1f}%")

# Visualizar os resultados
plt.figure(figsize=(7, 5))
plt.scatter(X[:, 0], X[:, 1], c=y, cmap='bwr', edgecolors='k', linewidths=0.5)
x_min, x_max = plt.xlim()
y_min = (-bias - weights[0] * x_min) / weights[1]
y_max = (-bias - weights[0] * x_max) / weights[1]
plt.plot([x_min, x_max], [y_min, y_max], 'k-', linewidth=2, label='Limite de decisão')
plt.xlabel('Feature 1')
plt.ylabel('Feature 2')
plt.title('Limite de Decisão do Perceptron — Dados Aleatórios')
plt.legend()
plt.tight_layout()
plt.show()