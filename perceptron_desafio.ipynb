# ============================================
# DESAFIO — Comparação com diferentes datasets
# ============================================
from sklearn.datasets import make_classification, make_moons, make_circles
from sklearn.preprocessing import StandardScaler

# Reutilizamos as funções da célula anterior
# (predict e train_perceptron já definidas acima)

# --- Gerador de datasets ---
datasets = {
    "Separável (make_classification)": make_classification(
        n_samples=200, n_features=2, n_redundant=0,
        n_clusters_per_class=1, random_state=42
    ),
    "Duas luas (make_moons)": make_moons(
        n_samples=200, noise=0.15, random_state=42
    ),
    "Círculos (make_circles)": make_circles(
        n_samples=200, noise=0.1, factor=0.5, random_state=42
    ),
}

fig, axes = plt.subplots(1, 3, figsize=(16, 5))

for ax, (nome, (X_d, y_d)) in zip(axes, datasets.items()):
    # Converter labels para -1 / +1
    y_d = np.where(y_d == 0, -1, 1)

    # Normalizar
    scaler = StandardScaler()
    X_d = scaler.fit_transform(X_d)

    # Treinar
    w, b = train_perceptron(X_d, y_d, learning_rate=0.1, epochs=20)

    # Acurácia
    preds = predict(X_d, w, b)
    acc = np.mean(preds == y_d) * 100

    # Plot dos pontos
    ax.scatter(X_d[:, 0], X_d[:, 1], c=y_d, cmap='bwr',
               edgecolors='k', linewidths=0.4, s=40)

    # Limite de decisão (se w[1] != 0)
    if abs(w[1]) > 1e-6:
        x_vals = np.linspace(X_d[:, 0].min()-0.5, X_d[:, 0].max()+0.5, 200)
        y_vals = (-b - w[0] * x_vals) / w[1]
        ax.plot(x_vals, y_vals, 'k-', linewidth=2)
        ax.set_ylim(X_d[:, 1].min()-0.5, X_d[:, 1].max()+0.5)

    ax.set_title(f"{nome}\nAcurácia: {acc:.1f}%", fontsize=11)
    ax.set_xlabel("Feature 1")
    ax.set_ylabel("Feature 2")

plt.suptitle("Comparação do Perceptron em Diferentes Datasets", fontsize=13, y=1.02)
plt.tight_layout()
plt.show()

# --- Resumo textual ---
print("\n=== RESUMO DOS RESULTADOS ===")
for nome, (X_d, y_d) in datasets.items():
    y_d = np.where(y_d == 0, -1, 1)
    X_d = StandardScaler().fit_transform(X_d)
    w, b = train_perceptron(X_d, y_d, epochs=20)
    acc = np.mean(predict(X_d, w, b) == y_d) * 100
    separavel = "✅ Linearmente separável" if acc > 95 else "❌ Não linearmente separável"
    print(f"{nome:40s} | Acurácia: {acc:5.1f}% | {separavel}")